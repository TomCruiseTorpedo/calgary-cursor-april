# Copy to .env.local for local development

# OpenRouter — optional; enables "Refine copy (OpenRouter)" on tool detail
OPENROUTER_API_KEY=
# Optional; defaults to hy3 preview free if unset
OPENROUTER_MODEL=tencent/hy3-preview:free

# Site URL for OpenRouter attribution headers (optional)
OPENROUTER_APP_URL=http://localhost:3000

# Use mock ingest (default true). Set to false when RSS/GitHub providers exist.
USE_MOCK_DATA=true

# Live signal river + RSS tool evidence ($0 HTTP). Opt-in: slower / flakier first load.
ENABLE_RSS_INGEST=false

# When ENABLE_RSS_INGEST=true, HN Algolia + GitHub Atom run by default.
# Set either to the string "false" to disable that leg:
# ENABLE_HN_ALGOLIA=false
# ENABLE_GITHUB_ATOM=false

# HN Algolia (optional overrides)
# HN_ALGOLIA_HITS=14
# HN_ALGOLIA_TAGS=front_page
# HN_ALGOLIA_QUERY=          # e.g. MCP — empty = front page only
# HN_ALGOLIA_TIMEOUT_MS=10000

# GitHub Atom (optional)
# GITHUB_TOKEN=              # raises rate limits for atom fetches
# GITHUB_ATOM_ITEMS_PER_FEED=4
# GITHUB_ATOM_MAX_TOTAL=28

# Per-feed timeout (ms). Default 8000.
# RSS_FEED_TIMEOUT_MS=8000
# Cache merged RSS+mock results (ms). Default 10 minutes.
RSS_CACHE_TTL_MS=600000
# Only ingest items newer than this many days (default 14).
RSS_MAX_AGE_DAYS=14
# Cap RSS-derived evidence rows per tool (default 12).
RSS_MAX_EVIDENCE_PER_TOOL=12
